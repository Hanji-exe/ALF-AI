{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/chat",
      "dest": "main.py"
    },
    {
      "src": "/feedback",
      "dest": "main.py"
    },
    {
      "src": "/feedbacks",
      "dest": "main.py"
    }
  ]
}